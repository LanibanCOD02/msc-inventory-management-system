# Server Configuration
PORT=3000

# Authentication
# Replace this with a strong, random string in production.
# Generate one by running this command in your terminal: 
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Directory Overrides (Optional)
# Uncomment and set this if you want to store uploads and database files in a custom external path.
# If left commented, the server will default to storing them in the project root.
# DATA_DIR=/absolute/path/to/data
